flowchart TB
    subgraph APP["Application Layer"]
        direction LR
        AGENT["Agent Runtime"]
        JOBMGR["Job Manager"]
        STORAGE["Distributed Storage"]
    end

    subgraph PROTO["Protocol Layer"]
        direction LR
        GOSSIP["GossipSub<br/>Pub/Sub"]
        KADEMLIA["Kademlia<br/>DHT Routing"]
        REQRES["Request-Response"]
    end

    subgraph IDENT["Identity Layer"]
        direction LR
        IDENTIFY["Identify"]
        NOISE["Noise Protocol<br/>Encryption"]
    end

    subgraph TRANS["Transport Layer"]
        direction LR
        QUIC["QUIC"]
        TCP["TCP"]
    end

    subgraph DISC["Discovery"]
        direction LR
        MDNS["mDNS<br/>Local Network"]
        BOOTSTRAP["Bootstrap Peers<br/>WAN"]
    end

    APP --> PROTO
    PROTO --> IDENT
    IDENT --> TRANS
    TRANS --> DISC
